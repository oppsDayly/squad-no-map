# Build output
/build*/
/out/
/release/
/install/

# Downloaded or locally installed SDKs/dependencies
/.deps/
/vcpkg_installed/

# Local demo/scratch data
/demo/
/tmp*/
/tmp_*

# Python cache
__pycache__/
*.py[cod]

# Lock/cache files
*.lock.json
/cmake/.CMakeBuildNumber

# Editor/OS files
.DS_Store
Thumbs.db
.vs/

# Local image assets used while regenerating embedded occluder data.
# Keep tools/img.py tracked; do not publish private screenshots or exports by accident.
/tools/*
!/tools/
!/tools/img.py
